<Window x:Class="DiscogsSniper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Discogs Sniper PRO" Height="650" Width="1050" Background="#f3f4f6">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="5" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Cena Max:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                    <TextBox x:Name="txtMaxPrice" Width="45" Text="200" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Zysk %:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold" Foreground="#047857"/>
                    <TextBox x:Name="txtMinProfit" Width="35" Text="30" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Max dni:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold" Foreground="#1d4ed8"/>
                    <TextBox x:Name="txtMaxAge" Width="30" Text="3" VerticalContentAlignment="Center" ToolTip="Pokaż oferty nie starsze niż X dni"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Min. Stan:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                    <ComboBox x:Name="cmbMinCondition" Width="110" SelectedIndex="2" VerticalContentAlignment="Center">
                        <ComboBoxItem Content="Wszystkie (0)" Tag="0"/>
                        <ComboBoxItem Content="G+ i wyżej (4)" Tag="4"/>
                        <ComboBoxItem Content="VG i wyżej (5)" Tag="5"/>
                        <ComboBoxItem Content="VG+ i wyżej (6)" Tag="6"/>
                        <ComboBoxItem Content="NM i wyżej (7)" Tag="7"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="btnStart" Grid.Column="4" Content="START" Background="#16a34a" Foreground="White" FontWeight="Bold" Width="90" Height="30" HorizontalAlignment="Right" Margin="0,0,10,0" Click="BtnStart_Click"/>
                <Button x:Name="btnStop" Grid.Column="5" Content="STOP" Background="#dc2626" Foreground="White" FontWeight="Bold" Width="60" Height="30" IsEnabled="False" Margin="0,0,10,0" Click="BtnStop_Click"/>
                <Button x:Name="btnClearMemory" Grid.Column="6" Content="Wyczyść Pamięć" Background="#f59e0b" Foreground="White" FontWeight="Bold" Width="110" Height="30" Click="BtnClearMemory_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" Padding="10" CornerRadius="5" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Moje Wytwórnie" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="txtLabelId" Width="60" Margin="0,0,5,0" ToolTip="ID" VerticalContentAlignment="Center"/>
                        <TextBox x:Name="txtLabelName" Width="120" Margin="0,0,5,0" VerticalContentAlignment="Center"/>
                        <Button x:Name="btnAddLabel" Content="Dodaj" Width="50" Click="BtnAddLabel_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="gridLabels" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" RowHeight="28" VerticalContentAlignment="Center">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="ON" Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                  Click="CheckBoxActive_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Binding="{Binding Id}" Header="ID" IsReadOnly="True" Width="55"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="Nazwa" Width="*" IsReadOnly="True"/>
                            <DataGridTemplateColumn Width="45">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Usuń" Background="#ef4444" Foreground="White" BorderThickness="0" Margin="2" Cursor="Hand" Click="BtnDeleteLabel_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" Padding="10" CornerRadius="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Wyłapane Okazje" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <DataGrid x:Name="gridOffers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
          ItemsSource="{Binding}" MouseDoubleClick="GridOffers_MouseDoubleClick" 
          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#e5e7eb">

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDeal}" Value="True">
                                        <Setter Property="Background" Value="#dcfce7"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Czas" Binding="{Binding DateFound, StringFormat={}{0:HH:mm:ss}}" Width="70"/>
                            <DataGridTextColumn Header="Artysta / Tytuł" Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Stan" Binding="{Binding Condition}" Width="150"/>
                            <DataGridTextColumn Header="Cena (+Wysyłka)" Binding="{Binding TotalPrice, StringFormat={}{0:F2} zł}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="#047857"/>
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1f2937" Padding="10" CornerRadius="5" Margin="0,10,0,0">
            <ScrollViewer x:Name="scrollLogs">
                <TextBlock x:Name="txtLogs" Foreground="#10b981" FontFamily="Consolas" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>